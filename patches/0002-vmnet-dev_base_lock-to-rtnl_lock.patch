Replace removed dev_base_lock with rtnl_lock on kernel 6.12+

The dev_base_lock rwlock was removed from the kernel netdevice layer.
VMware vmnet bridge.c uses dev_lock_list/dev_unlock_list which expand
to read_lock(&dev_base_lock), breaking compilation on kernel 6.12+.

rtnl_lock()/rtnl_unlock() is the modern way to serialize against
netdev list mutations. Gated by kernel version so older kernels see
the original read_lock(&dev_base_lock) path.

Also adds explicit <linux/version.h> and <linux/rtnetlink.h> includes
since vmnetInt.h is included before compat_netdevice.h in bridge.c.

--- a/vmnet-only/vmnetInt.h
+++ b/vmnet-only/vmnetInt.h
@@ -23,6 +23,8 @@
 #define INCLUDE_ALLOW_MODULE
 #include "includeCheck.h"
 #include "driver-config.h"
+#include <linux/version.h>
+#include <linux/rtnetlink.h>
 
 
 #ifdef skb_shinfo
@@ -41,8 +43,17 @@
     compat_skb_set_network_header(skb, sizeof (struct ethhdr)),  \
     dev_queue_xmit(skb)                                   \
   )
+/*
+ * dev_base_lock was removed in newer kernels (gone on kernel 6.12+).
+ * rtnl_lock is the modern way to synchronize netdev list walks.
+ */
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(6, 12, 0)
+#define dev_lock_list()    rtnl_lock()
+#define dev_unlock_list()  rtnl_unlock()
+#else
 #define dev_lock_list()    read_lock(&dev_base_lock)
 #define dev_unlock_list()  read_unlock(&dev_base_lock)
+#endif
 
 
 extern struct proto vmnet_proto;
